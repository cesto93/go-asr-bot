TELEGRAM_BOT_TOKEN=your_bot_token_here
DEBUG=false

# Restrict bot to a single user (optional; 0 or unset = allow all)
# USER_ID=your_telegram_user_id

# Backend selection: "yzma" (default) or "crispasr"
# ASR_BACKEND=yzma

# yzma/Qwen3-ASR backend (default backend)
# MODEL_PATH=models/Qwen3-ASR-0.6B-Q8_0.gguf
# MMPROJ_PATH=models/mmproj-Qwen3-ASR-0.6B-Q8_0.gguf
# YZMA_LIB=llamacpp

# CrispASR backend (requires building CrispASR C library in lib/crispasr/)
# CRISPASR_MODEL_PATH=/opt/go-asr-bot/models/parakeet-tdt-0.6b-v3.gguf
# CRISPASR_THREADS=4
